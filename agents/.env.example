# ── AI Models ────────────────────────────────────────────────────
# Priority: OpenClaw → Groq (free, cloud) → Claude → Ollama (local, opt-in)

# Option A: OpenClaw / CMDOP — daftar di cmdop.com
CMDOP_API_KEY=your_cmdop_api_key_here
CMDOP_SERVER=grpc.cmdop.com:443

# Option B: Groq — GRATIS, cloud, cepat — console.groq.com (RECOMMENDED)
OPENAI_COMPAT_API_KEY=your_groq_api_key_here
OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai
OPENAI_COMPAT_MODEL=llama-3.3-70b-versatile

# Option C: Claude — console.anthropic.com (last resort, berbayar)
ANTHROPIC_API_KEY=your_claude_api_key_here

# Option D: Ollama local — opt-in only, tidak dipakai di cloud deployment
# Set OLLAMA_ENABLED=true hanya kalau run local dengan Ollama installed
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ── Mantle Network ────────────────────────────────────────────────
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_CHAIN_ID=5003
RWAI_DEPLOYMENTS_FILE=../contracts/deployments.json

# Private key of the agent wallet (signs on-chain transactions)
# Fill with deployer private key after contracts are deployed
AGENT_PRIVATE_KEY=your_agent_wallet_private_key_here

# ── Frontend ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,https://your-production-app.vercel.app

# Set true only for trusted backend deployments that should submit HybridVault agent executions.
AUTONOMOUS_EXECUTION_ENABLED=false
