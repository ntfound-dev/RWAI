NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_AGENT_API_URL=http://localhost:8001
AGENT_API_URL=http://localhost:8001
ANTHROPIC_API_KEY=your_claude_api_key_optional_frontend_fallback

# RPC Endpoints (Sepolia/Ethereum L1)
NEXT_PUBLIC_SEPOLIA_RPC=https://rpc.sepolia.org
# For production, use:
# NEXT_PUBLIC_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# NEXT_PUBLIC_SEPOLIA_RPC=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# RPC Endpoints (Mantle)
NEXT_PUBLIC_MANTLE_TESTNET_RPC=https://rpc.sepolia.mantle.xyz
NEXT_PUBLIC_MANTLE_MAINNET_RPC=https://rpc.mantle.xyz

# After deploying contracts, copy from contracts/deployments.json:
NEXT_PUBLIC_RWAI_REGISTRY=0x...
NEXT_PUBLIC_COMPLIANCE_LOG=0x...
NEXT_PUBLIC_YIELD_ORACLE=0x...
NEXT_PUBLIC_AGENT_EXECUTOR=0x...
NEXT_PUBLIC_PORTFOLIO_VAULT=0x...
NEXT_PUBLIC_HYBRID_VAULT=0x...
