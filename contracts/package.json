{
  "name": "rwai-contracts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "preflight:sepolia": "hardhat run scripts/preflight.ts --network mantleSepolia",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network mantleTestnet",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network mantleSepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network mantle",
    "verify:testnet": "hardhat run scripts/verify.ts --network mantleTestnet",
    "verify:sepolia": "hardhat run scripts/verify.ts --network mantleSepolia",
    "register:agents": "hardhat run scripts/registerAgents.ts --network mantleSepolia",
    "sync:deployment": "ts-node scripts/syncDeployment.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@pythnetwork/pyth-sdk-solidity": "^4.3.1"
  }
}
